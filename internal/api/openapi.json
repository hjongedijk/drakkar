{
  "openapi": "3.1.0",
  "info": {
    "title": "Drakkar API",
    "version": "0.1.86",
    "description": "Drakkar NZB/Usenet VFS media manager REST API.\n\nAuthentication: Pass a session cookie (`drakkar_session`) or Bearer API token (`Authorization: Bearer <token>` or `X-Api-Key: <token>`) on all requests except public paths.",
    "contact": { "name": "Drakkar", "url": "https://github.com/hjongedijk/drakkar" }
  },
  "servers": [{ "url": "", "description": "Current host" }],
  "components": {
    "securitySchemes": {
      "BearerAuth": { "type": "http", "scheme": "bearer" },
      "ApiKeyHeader": { "type": "apiKey", "in": "header", "name": "X-Api-Key" },
      "CookieAuth": { "type": "apiKey", "in": "cookie", "name": "drakkar_session" }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": { "error": { "type": "string" } }
      },
      "QueueItem": {
        "type": "object",
        "properties": {
          "queueItemId": { "type": "integer" },
          "libraryItemId": { "type": "integer" },
          "libraryTitle": { "type": "string" },
          "state": { "type": "string", "enum": ["pending","searching","selected","downloading","available","failed"] },
          "failureReason": { "type": "string" },
          "selectedReleaseId": { "type": "integer" },
          "nzbDocumentId": { "type": "integer" },
          "nzbFileName": { "type": "string" },
          "nzbFileCount": { "type": "integer" },
          "nzbSegmentCount": { "type": "integer" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      },
      "LibraryItem": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "mediaType": { "type": "string", "enum": ["movie","episode","tv"] },
          "title": { "type": "string" },
          "year": { "type": "integer" },
          "overview": { "type": "string" },
          "posterUrl": { "type": "string" },
          "backdropUrl": { "type": "string" },
          "available": { "type": "boolean" },
          "requestedAt": { "type": "string", "format": "date-time" },
          "queueState": { "type": "string" },
          "failureReason": { "type": "string" },
          "selectedReleaseId": { "type": "integer" },
          "tmdbId": { "type": "integer" },
          "tvdbId": { "type": "integer" },
          "imdbId": { "type": "string" },
          "availableCount": { "type": "integer" },
          "missingCount": { "type": "integer" },
          "seasonNumber": { "type": "integer" },
          "episodeNumber": { "type": "integer" }
        }
      },
      "ReleaseCandidate": {
        "type": "object",
        "properties": {
          "selectedReleaseId": { "type": "integer" },
          "releaseCandidateId": { "type": "integer" },
          "libraryItemId": { "type": "integer" },
          "title": { "type": "string" },
          "externalUrl": { "type": "string" },
          "indexerName": { "type": "string" },
          "sizeBytes": { "type": "integer", "format": "int64" },
          "postedAt": { "type": "string", "format": "date-time" },
          "score": { "type": "number" },
          "customFormatScore": { "type": "number" },
          "selected": { "type": "boolean" },
          "rejected": { "type": "boolean" },
          "rejectReason": { "type": "string" },
          "failureCount": { "type": "integer" },
          "lastFailureReason": { "type": "string" }
        }
      },
      "BlocklistItem": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "key": { "type": "string" },
          "keyType": { "type": "string" },
          "reason": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "releaseTitle": { "type": "string" },
          "indexerName": { "type": "string" },
          "sizeBytes": { "type": "integer", "format": "int64" }
        }
      },
      "QualityProfile": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "isDefault": { "type": "boolean" },
          "resolutions": { "type": "array", "items": { "type": "string" } },
          "sources": { "type": "array", "items": { "type": "string" } },
          "codecs": { "type": "array", "items": { "type": "string" } },
          "languages": { "type": "array", "items": { "type": "string" } },
          "audioFormats": { "type": "array", "items": { "type": "string" } },
          "hdrFormats": { "type": "array", "items": { "type": "string" } },
          "excludePatterns": { "type": "array", "items": { "type": "string" } },
          "preferProper": { "type": "boolean" },
          "preferRepack": { "type": "boolean" },
          "rejectCam": { "type": "boolean" },
          "allowUpgrade": { "type": "boolean" },
          "cutoffResolution": { "type": "string" },
          "minimumAgeHours": { "type": "number" },
          "minMbPerMinute": { "type": "number" },
          "maxMbPerMinute": { "type": "number" }
        }
      },
      "TaskSchedule": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "label": { "type": "string" },
          "group": { "type": "string" },
          "interval": { "type": "string" },
          "automated": { "type": "boolean" },
          "lastRunAt": { "type": "string", "format": "date-time" },
          "lastRunState": { "type": "string" }
        }
      },
      "SubtitleFile": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "libraryItemId": { "type": "integer" },
          "provider": { "type": "string" },
          "language": { "type": "string" },
          "path": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "APIToken": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "userId": { "type": "integer" },
          "name": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "lastUsedAt": { "type": "string", "format": "date-time" },
          "expiresAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "security": [
    { "BearerAuth": [] },
    { "ApiKeyHeader": [] },
    { "CookieAuth": [] }
  ],
  "tags": [
    { "name": "Auth", "description": "Authentication, sessions, and API tokens" },
    { "name": "Queue", "description": "Download queue management" },
    { "name": "Library", "description": "Media library items and searches" },
    { "name": "Releases", "description": "Release candidates and selection" },
    { "name": "Requests", "description": "Seerr request sync and management" },
    { "name": "Blocklist", "description": "Release blocklist management" },
    { "name": "Health", "description": "Symlink and NZB article health checks" },
    { "name": "Tasks", "description": "Scheduled task status" },
    { "name": "Quality", "description": "Quality profiles and definitions" },
    { "name": "Subtitles", "description": "Subtitle files and search" },
    { "name": "Settings", "description": "System configuration" },
    { "name": "Policies", "description": "Queue decision policies" },
    { "name": "Discover", "description": "Browse TMDB catalogue" },
    { "name": "Media Players", "description": "Plex and Jellyfin integration" },
    { "name": "VFS", "description": "Virtual filesystem browser" },
    { "name": "NZBs", "description": "NZB file import" },
    { "name": "Webhooks", "description": "Inbound webhooks from Seerr" }
  ],
  "paths": {
    "/api/status": {
      "get": {
        "tags": ["Settings"],
        "summary": "Service status and integration health",
        "responses": {
          "200": { "description": "Service status object with integration statuses and runtime info" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Login with username and password",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful — sets session cookie" },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout — clears session cookie",
        "security": [],
        "responses": { "200": { "description": "Logged out" } }
      }
    },
    "/api/auth/me": {
      "get": {
        "tags": ["Auth"],
        "summary": "Get current user info",
        "responses": {
          "200": { "description": "User object with id, username, role" }
        }
      }
    },
    "/api/auth/tokens": {
      "get": {
        "tags": ["Auth"],
        "summary": "List API tokens for current user",
        "responses": {
          "200": {
            "description": "Array of API tokens",
            "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/APIToken" } } } }
          }
        }
      },
      "post": {
        "tags": ["Auth"],
        "summary": "Create a new API token",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "expiresAt": { "type": "string", "format": "date-time", "description": "Optional expiry (empty = no expiry)" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created token — raw `token` field only returned here, not in list endpoint",
            "content": { "application/json": { "schema": { "allOf": [{ "$ref": "#/components/schemas/APIToken" }, { "type": "object", "properties": { "token": { "type": "string" } } }] } } }
          }
        }
      }
    },
    "/api/auth/tokens/{id}": {
      "delete": {
        "tags": ["Auth"],
        "summary": "Delete an API token",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Deleted" } }
      }
    },
    "/api/users": {
      "get": {
        "tags": ["Auth"],
        "summary": "List users",
        "responses": { "200": { "description": "Array of users" } }
      },
      "post": {
        "tags": ["Auth"],
        "summary": "Create user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "role": { "type": "string", "default": "admin" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Created user" } }
      }
    },
    "/api/users/{id}/password": {
      "put": {
        "tags": ["Auth"],
        "summary": "Change user password",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "password": { "type": "string" } } } } }
        },
        "responses": { "200": { "description": "Password changed" } }
      }
    },
    "/api/queue": {
      "get": {
        "tags": ["Queue"],
        "summary": "Get current queue and work-queue status",
        "responses": {
          "200": {
            "description": "Queue items and work queue status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": { "type": "array", "items": { "$ref": "#/components/schemas/QueueItem" } },
                    "workQueue": { "type": "object", "properties": { "paused": { "type": "boolean" }, "depth": { "type": "integer" } } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/queue/pause": {
      "post": {
        "tags": ["Queue"],
        "summary": "Pause the work queue",
        "responses": { "200": { "description": "Updated work queue status" } }
      }
    },
    "/api/queue/resume": {
      "post": {
        "tags": ["Queue"],
        "summary": "Resume the work queue",
        "responses": { "200": { "description": "Updated work queue status" } }
      }
    },
    "/api/queue/{id}/retry": {
      "post": {
        "tags": ["Queue"],
        "summary": "Retry a single queue item",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Result with action taken" } }
      }
    },
    "/api/queue/{id}/action": {
      "post": {
        "tags": ["Queue"],
        "summary": "Perform an action on a queue item",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "action": { "type": "string", "enum": ["retry","reset","blocklist","skip"] } } } } }
        },
        "responses": { "200": { "description": "Result with action taken" } }
      }
    },
    "/api/queue/bulk-action": {
      "post": {
        "tags": ["Queue"],
        "summary": "Perform an action on multiple queue items",
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "queueItemIds": { "type": "array", "items": { "type": "integer" } }, "action": { "type": "string" } } } } }
        },
        "responses": { "200": { "description": "Processed count" } }
      }
    },
    "/api/queue/retry-failed": {
      "post": {
        "tags": ["Queue"],
        "summary": "Retry all failed queue items",
        "responses": {
          "200": {
            "description": "Retry result",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "processed": { "type": "integer" }, "retried": { "type": "integer" }, "failed": { "type": "integer" } } } } }
          }
        }
      }
    },
    "/api/queue/clear-failed": {
      "post": {
        "tags": ["Queue"],
        "summary": "Clear all failed queue items",
        "responses": { "200": { "description": "Number cleared" } }
      }
    },
    "/api/library": {
      "get": {
        "tags": ["Library"],
        "summary": "List library items with pagination and filters",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer", "default": 25 } },
          { "name": "q", "in": "query", "schema": { "type": "string" }, "description": "Title search" },
          { "name": "kind", "in": "query", "schema": { "type": "string", "enum": ["all","movie","tv","episode"] } },
          { "name": "state", "in": "query", "schema": { "type": "string", "enum": ["all","available","missing","active","failed"] } }
        ],
        "responses": {
          "200": {
            "description": "Paginated library items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "items": { "type": "array", "items": { "$ref": "#/components/schemas/LibraryItem" } },
                    "page": { "type": "integer" },
                    "pageSize": { "type": "integer" },
                    "total": { "type": "integer" },
                    "totalPages": { "type": "integer" },
                    "totalMonitored": { "type": "integer" },
                    "sumAvailable": { "type": "integer" },
                    "sumMissing": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/library/search": {
      "get": {
        "tags": ["Library"],
        "summary": "Full-text search library items",
        "parameters": [{ "name": "q", "in": "query", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Matching items" } }
      }
    },
    "/api/library/{id}/details": {
      "get": {
        "tags": ["Library"],
        "summary": "Get detailed library item (with seasons/episodes)",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Library detail with seasons, episodes, monitoring mode" } }
      }
    },
    "/api/library/{id}/search": {
      "post": {
        "tags": ["Library"],
        "summary": "Trigger immediate search for a specific library item",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "202": { "description": "Search started — SSE event `library.search` fires on completion" } }
      }
    },
    "/api/library/{id}/reset": {
      "post": {
        "tags": ["Library"],
        "summary": "Reset a library item back to pending state",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Reset confirmed" } }
      }
    },
    "/api/library/{id}/republish": {
      "post": {
        "tags": ["Library"],
        "summary": "Republish an existing selected release",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Republish result" } }
      }
    },
    "/api/library/{id}/restore-rejected": {
      "post": {
        "tags": ["Library"],
        "summary": "Restore rejected release candidates for retry",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Restored count" } }
      }
    },
    "/api/library/{id}/replacements": {
      "post": {
        "tags": ["Library"],
        "summary": "Search for quality replacement releases",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Replacement candidates found" } }
      }
    },
    "/api/library/{id}/profile": {
      "get": {
        "tags": ["Library"],
        "summary": "Get per-item quality profile override",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Profile or null" } }
      },
      "put": {
        "tags": ["Library"],
        "summary": "Set per-item quality profile override",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": { "application/json": { "schema": { "type": "object", "properties": { "profileId": { "type": "integer", "nullable": true } } } } }
        },
        "responses": { "200": { "description": "Updated" } }
      }
    },
    "/api/library/{id}/grab-history": {
      "get": {
        "tags": ["Library"],
        "summary": "Get grab history for a library item",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Grab history entries" } }
      }
    },
    "/api/library/search-pending": {
      "post": {
        "tags": ["Library"],
        "summary": "Search all pending/missing library items in background",
        "responses": { "202": { "description": "Started — SSE event `library.search_pending` on completion" } }
      }
    },
    "/api/library/search-upgrades": {
      "post": {
        "tags": ["Library"],
        "summary": "Search quality upgrades for available items",
        "responses": { "202": { "description": "Started — SSE event `library.search_upgrades` on completion" } }
      }
    },
    "/api/library/republish-pending": {
      "post": {
        "tags": ["Library"],
        "summary": "Republish all library items with a selected release but no symlink",
        "responses": { "202": { "description": "Started — SSE event `library.republish_pending` on completion" } }
      }
    },
    "/api/library/reset-orphaned-available": {
      "post": {
        "tags": ["Library"],
        "summary": "Reset available items with no symlink back to pending",
        "responses": { "202": { "description": "Started — SSE event `library.reset_orphaned` on completion" } }
      }
    },
    "/api/library/fill-missing-episodes": {
      "post": {
        "tags": ["Library"],
        "summary": "Create library items for episodes not yet tracked (TMDB sync)",
        "responses": {
          "200": {
            "description": "Result",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "showsProcessed": { "type": "integer" }, "episodesFound": { "type": "integer" }, "itemsCreated": { "type": "integer" } } } } }
          }
        }
      }
    },
    "/api/library/backfill-metadata": {
      "post": {
        "tags": ["Library"],
        "summary": "Re-enrich library items with latest TMDB metadata",
        "responses": {
          "200": {
            "description": "Result",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "processedMovies": { "type": "integer" }, "processedShows": { "type": "integer" }, "enriched": { "type": "integer" }, "failed": { "type": "integer" } } } } }
          }
        }
      }
    },
    "/api/releases/{libraryItemId}": {
      "get": {
        "tags": ["Releases"],
        "summary": "Get release candidates for a library item",
        "parameters": [{ "name": "libraryItemId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": {
            "description": "Release candidates",
            "content": { "application/json": { "schema": { "type": "object", "properties": { "items": { "type": "array", "items": { "$ref": "#/components/schemas/ReleaseCandidate" } } } } } }
          }
        }
      }
    },
    "/api/releases/{id}/select": {
      "post": {
        "tags": ["Releases"],
        "summary": "Manually select a release candidate",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "releaseCandidateId" }],
        "responses": { "200": { "description": "Selection result" } }
      }
    },
    "/api/releases/{id}/reject": {
      "post": {
        "tags": ["Releases"],
        "summary": "Reject a release candidate",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object", "properties": { "reason": { "type": "string", "default": "manual_reject" } } } } }
        },
        "responses": { "200": { "description": "Rejection result" } }
      }
    },
    "/api/releases/{id}/restore": {
      "post": {
        "tags": ["Releases"],
        "summary": "Restore a previously rejected release candidate",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Restore result" } }
      }
    },
    "/api/releases/{id}/skip": {
      "post": {
        "tags": ["Releases"],
        "summary": "Skip (soft-reject) a release candidate",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": { "200": { "description": "Skip result" } }
      }
    },
    "/api/requests": {
      "get": {
        "tags": ["Requests"],
        "summary": "List Seerr requests",
